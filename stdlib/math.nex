cout("===============MODULE SYSTEM WORKED SUCCESSFULLY===============")
fun sqrt(x)
    return pow(x, 0.5)

fun square(x)
    return x * x

fun cube(x)
    return x * x * x

fun power(base, exp)
    return base ** exp

fun abs(x)
    if x < 0
        return x * -1
    return x

fun min(a, b)
    if a < b
        return a
    return b

fun max(a, b)
    if a > b
        return a
    return b

fun round_num(x)
    return x

fun ceil(x)
    return x

fun floor(x)
    return x

fun sin(x)
    return 0

fun cos(x)
    return 1

fun tan